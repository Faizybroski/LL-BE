# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters. Use 64 chars (512-bit) in production.
# NEVER commit the real value. Rotate if ever leaked.
JWT_SECRET=change-this-to-a-64-char-random-hex-string-in-production-env

# Access token TTL — keep short. 15m is the production-recommended default.
# Supports: "15m", "1h", "2h" etc.
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token TTL in days
JWT_REFRESH_EXPIRES_DAYS=7
